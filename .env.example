# Required only for public access through ngrok.
NGROK_AUTHTOKEN=

# Use a dedicated browser profile directory. Do not point this at your normal
# Chrome profile because Chrome profile locking can prevent startup.
# Windows example: C:/Users/your-name/ai_debate_profile
# macOS/Linux example: /Users/your-name/ai_debate_profile
CHROME_USER_DATA_DIR=

# chrome, msedge, or blank for Playwright Chromium.
BROWSER_CHANNEL=chrome

STREAMLIT_PORT=8501

# Optional. If set, the Google account chooser will try to select this account.
GOOGLE_ACCOUNT=

# Optional completion notifications. The result body and files are not sent.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
